{
  "query": {
    "bool": {
      "must": [
        {
          "terms": { "namespace": ["https://iri.suomi.fi/terminology/test/"] }
        },
        {
          "range": {
            "modified": {
              "gte": "2024-07-24T00:00:00",
              "lte": "2024-07-25T00:00:00"
            }
          }
        },
        {
          "bool": {
            "minimum_should_match": "1",
            "should": [
              {
                "multi_match": {
                  "boost": 3.0,
                  "fields": ["label.*"],
                  "operator": "and",
                  "query": "Search"
                }
              },
              {
                "multi_match": {
                  "boost": 2.0,
                  "fields": ["label.*.edge"],
                  "operator": "and",
                  "query": "Search"
                }
              },
              {
                "multi_match": {
                  "fields": ["label.*.ngram"],
                  "operator": "or",
                  "query": "Search"
                }
              }
            ]
          }
        },
        { "term": { "status": { "value": "DRAFT" } } }
      ]
    }
  },
  "size": 50
}
